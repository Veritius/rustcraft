    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'rustcraft_client'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=rustcraft_client",
                    "--package=rustcraft_client"
                ],
                "filter": {
                    "name": "rustcraft_client",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'rustcraft_client'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=rustcraft_client",
                    "--package=rustcraft_client"
                ],
                "filter": {
                    "name": "rustcraft_client",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in library 'rustcraft_shared'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--lib",
                    "--package=rustcraft_shared"
                ],
                "filter": {
                    "name": "rustcraft_shared",
                    "kind": "lib"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
