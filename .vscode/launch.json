                    "name": "rustcraft_server",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'rustcraft_server'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=rustcraft_server",
                    "--package=rustcraft_server"
                ],
                "filter": {
                    "name": "rustcraft_server",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
